# ─── 飞书多维表格 ────────────────────────────────────────────────────────────────
# 在飞书多维表格 URL 中找到: https://xxx.feishu.cn/base/<APP_TOKEN>?table=<TABLE_ID>
LARK_APP_TOKEN=EyQJblriXXXXXXXXXXXXXXXX
LARK_LEDGER_TABLE=tblsHPalXXXXXXXX
LARK_ACCOUNT_TABLE=tbl9Ff6lXXXXXXXX

# ─── lark-cli / Windows 兼容（可选）──────────────────────────────────────────────
# 建议始终使用最新版：npm install -g @larksuite/cli@latest
# 验证版本：lark-cli --version
# 默认直接调用 PATH 中的 lark-cli；Windows 若遇到 spawn lark-cli ENOENT，可指定绝对路径
# 优先指向 lark-cli.exe，避免 .cmd shim + shell 模式导致中文 JSON 参数乱码
# LARK_CLI_BIN=C:\Tools\lark-cli\lark-cli.exe

# ─── 消息接入模式（默认机器人自动响应）────────────────────────────────────────────
# 默认 long：机器人收到消息事件后回复原会话，不需要手动填写群 ID
LARK_EVENT_MODE=long
# poll 是兼容/排障模式，需要指定群聊或单聊 ID（oc_xxx 格式）
# 获取方式: lark-cli im +chat-search --keyword "你的群名"
# LARK_EVENT_MODE=poll
# LARK_CHAT_ID=oc_your_chat_id_here
# poll 仅在“首次启动 / state 丢失”时生效：从现在往前补拉 N 秒的历史消息（默认 86400 = 24h）
# LARK_POLL_BACKFILL_SECONDS=86400
# long/webhook 模式会记录见过的 chat_id，并定时补拉漏掉的消息；无 chat_id 时自动跳过
# LARK_CATCHUP_POLL_INTERVAL_MS=600000
# lark-cli 长连接默认使用 --force，避免本机残留订阅实例导致收不到消息；设 0 可关闭
# LARK_CLI_EVENT_SUBSCRIBE_FORCE=1
# 长连接报错但进程未退出时，watchdog 会主动杀掉并重连
# LARK_LONG_WATCHDOG_MS=300000

# ─── Webhook 模式（可选，配置后替代轮询）─────────────────────────────────────────
# 配置飞书事件订阅时，把回调地址指向 http(s)://your-host:<port>/
# 并在飞书后台填写同一个 Verification Token
# LARK_WEBHOOK_PORT=9326
# LARK_WEBHOOK_HOST=0.0.0.0
# LARK_VERIFICATION_TOKEN=your-feishu-verification-token

# ─── LLM（OpenAI 兼容 /chat/completions）──────────────────────────────────────────
# 用于自由自然语言解析；快捷格式「晚餐，68，微信」「余额宝转招行500」可不配 LLM。
# 默认硅基流动；可换任意兼容端点：
# BOOKKEEPING_LLM_CHAT_URL=https://api.siliconflow.cn/v1/chat/completions
# 或只设基址（自动拼 /chat/completions）：
# OPENAI_BASE_URL=https://api.openai.com/v1
# 密钥任选其一：
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
# OPENAI_API_KEY=
# LLM_API_KEY=
# 结构化解析（Function Calling，失败自动回退正文 JSON）：默认开启
# BOOKKEEPING_PARSE_STRUCTURED=0
# 图片 OCR 仍建议走硅基视觉模型；若自建可设：
# LARK_OCR_CHAT_URL=https://api.siliconflow.cn/v1/chat/completions

# ─── 双人记账（守护进程 lark-bookkeeping-daemon.mjs）────────────────────────────
# 飞书发言人 open_id / user_id / 显示名 → 与「流水」表「记账人」单选选项一致的字符串
# 例: LARK_BOOKKEEPING_USER_OWNER_MAP={"ou_xxx":"Erkou","ou_yyy":"Darcen"}
# LARK_BOOKKEEPING_USER_OWNER_MAP=
# 未映射到 map 的发言人默认记账人（与飞书单选选项一致）
# LARK_BOOKKEEPING_DEFAULT_BOOKKEEPER=Darcen
# 群昵称「二老师」等 → 账户拥有者，用于「查账户」类扩展（JSON）
# LARK_BOOKKEEPING_OWNER_TOKEN_ALIASES={"二老师":"Erkou"}
# 多群允许列表（逗号分隔）；不设则响应机器人收到的所有会话
# LARK_BOOKKEEPING_CHAT_IDS=
# 记账人≠账户拥有者时是否校验（默认开启）；设为 0 关闭
# LARK_BOOKKEEPING_OWNER_GUARD=1
# 启用后 IM 尽量以回复线程发送（依赖 lark-cli +messages-reply）
# LARK_BOOKKEEPING_ENABLE_CHAT_REPLY=0
# 回复身份：auto 先尝试 bot，失败后回退 user；也可固定 bot 或 user
# LARK_REPLY_AS=auto

# ─── 本地状态 / 日志目录（可选）──────────────────────────────────────────────────
# 默认写入用户目录下 .local/share/lark-bookkeeping；Windows 可改到固定目录
# LARK_BOOKKEEPING_DATA_DIR=C:\lark-bookkeeping-data

# ─── CLI 记账（lark-record.mjs）「记账人」列 ─────────────────────────────────────
# 与上表「记账人」选项一致时写入该列；不设则不写该字段
# LARK_RECORD_BOOKKEEPER=Darcen

# ─── 可选配置 ─────────────────────────────────────────────────────────────────────
# 是否在记账后发送飞书 IM 确认消息（默认: 1）
LARK_RECORD_SEND_IM=1

# AI 解析超时（毫秒，默认 120000）。多笔记账时模型可能较慢。
# LARK_PARSE_TIMEOUT_MS=120000
# LARK_BOOKKEEPING_PARSE_TIMEOUT_MS=120000
# 解析失败自动重试次数（仅守护进程，默认 2）
# LARK_BOOKKEEPING_PARSE_RETRIES=2

# ─── SiliconFlow 模型路由（可选）─────────────────────────────────────────────────
# 配置后自动路由到最合适的模型，不配置则默认使用 DeepSeek-V3
# 路由器: https://github.com/PUDAOCHEN031101/model-router-mcp
# SILICON_ROUTER_PYTHON=/path/to/siliconflow_router/.venv/bin/python
# SILICON_ROUTER_CLI=/path/to/siliconflow_router/router_cli.py
