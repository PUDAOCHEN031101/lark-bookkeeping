# ─── 飞书多维表格 ────────────────────────────────────────────────────────────────
# 在飞书多维表格 URL 中找到: https://xxx.feishu.cn/base/<APP_TOKEN>?table=<TABLE_ID>
LARK_APP_TOKEN=EyQJblriXXXXXXXXXXXXXXXX
LARK_LEDGER_TABLE=tblsHPalXXXXXXXX
LARK_ACCOUNT_TABLE=tbl9Ff6lXXXXXXXX

# ─── 飞书聊天 ID ──────────────────────────────────────────────────────────────────
# 守护进程监听的群聊或单聊 ID（oc_xxx 格式）
# 获取方式: lark-cli im +chat-search --keyword "你的群名"
LARK_CHAT_ID=oc_your_chat_id_here

# ─── SiliconFlow API ──────────────────────────────────────────────────────────────
# 注册地址: https://siliconflow.cn
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here

# ─── 可选配置 ─────────────────────────────────────────────────────────────────────
# 是否在记账后发送飞书 IM 确认消息（默认: 1）
LARK_RECORD_SEND_IM=1

# ─── SiliconFlow 模型路由（可选）─────────────────────────────────────────────────
# 配置后自动路由到最合适的模型，不配置则默认使用 DeepSeek-V3
# 路由器: https://github.com/PUDAOCHEN031101/model-router-mcp
# SILICON_ROUTER_PYTHON=/path/to/siliconflow_router/.venv/bin/python
# SILICON_ROUTER_CLI=/path/to/siliconflow_router/router_cli.py
